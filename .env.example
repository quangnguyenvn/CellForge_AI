# CellForge AI local defaults
CELLFORGE_ENV=local
CELLFORGE_TRACE_PROVIDER=mock
CELLFORGE_BRIEF_PROVIDER=local

# Arize AX hosted tracing
# Set CELLFORGE_TRACE_PROVIDER=arize_ax and fill these for the hackathon Arize track.
ARIZE_SPACE_ID=
ARIZE_API_KEY=
ARIZE_PROJECT_NAME=cellforge-ai
ARIZE_ENDPOINT=
ARIZE_COLLECTOR_ENDPOINT=

# Phoenix Cloud / self-hosted Phoenix
# Leave these empty to use the local mock adapter.
PHOENIX_API_KEY=
PHOENIX_SPACE_ID=
PHOENIX_ENDPOINT=
PHOENIX_COLLECTOR_ENDPOINT=
PHOENIX_PROJECT_NAME=cellforge-ai

# Gemini / Google Cloud
GOOGLE_CLOUD_PROJECT=cellforge-ai-demo
GOOGLE_CLOUD_LOCATION=global
GOOGLE_GENAI_USE_ENTERPRISE=True
GEMINI_MODEL=gemini-2.5-pro
# Set CELLFORGE_BRIEF_PROVIDER=gemini after Google ADC is configured locally.

# Optional storage used for real paper extraction
GCS_BUCKET=
DOCUMENT_AI_PROCESSOR_ID=
